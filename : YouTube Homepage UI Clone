<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YouTube Clone</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f9f9f9;
}

/* Header */
.header{
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:60px;
    background:white;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:0 20px;
    border-bottom:1px solid #ddd;
    z-index:1000;
}

.logo{
    display:flex;
    align-items:center;
    font-size:24px;
    font-weight:bold;
    color:red;
}

.logo span{
    color:black;
    margin-left:5px;
}

.search-bar{
    display:flex;
    width:50%;
}

.search-bar input{
    flex:1;
    padding:10px;
    border:1px solid #ccc;
    border-radius:20px 0 0 20px;
    outline:none;
}

.search-bar button{
    padding:10px 20px;
    border:1px solid #ccc;
    background:#f1f1f1;
    border-radius:0 20px 20px 0;
    cursor:pointer;
}

.profile{
    width:40px;
    height:40px;
    border-radius:50%;
    background:#2196f3;
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    font-weight:bold;
}

/* Sidebar */
.sidebar{
    position:fixed;
    top:60px;
    left:0;
    width:220px;
    height:100%;
    background:white;
    padding-top:20px;
    border-right:1px solid #ddd;
}

.sidebar ul{
    list-style:none;
}

.sidebar li{
    padding:15px 20px;
    cursor:pointer;
}

.sidebar li:hover{
    background:#f1f1f1;
}

/* Main Content */
.main{
    margin-left:220px;
    margin-top:80px;
    padding:20px;
}

.video-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
    gap:20px;
}

.video-card{
    background:white;
    border-radius:10px;
    overflow:hidden;
    cursor:pointer;
    transition:.3s;
}

.video-card:hover{
    transform:scale(1.02);
}

.thumbnail{
    width:100%;
    height:180px;
    background:#ddd;
}

.thumbnail img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.video-info{
    display:flex;
    padding:12px;
}

.channel-icon{
    width:40px;
    height:40px;
    border-radius:50%;
    background:#666;
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    margin-right:10px;
}

.video-details h4{
    margin-bottom:5px;
    font-size:15px;
}

.video-details p{
    color:#666;
    font-size:13px;
}

/* Responsive */
@media(max-width:768px){

    .sidebar{
        width:70px;
    }

    .sidebar li{
        text-align:center;
        font-size:12px;
        padding:15px 5px;
    }

    .main{
        margin-left:70px;
    }

    .search-bar{
        width:40%;
    }
}
</style>
</head>
<body>

<!-- Header -->
<div class="header">
    <div class="logo">
        ▶ <span>YouTube</span>
    </div>

    <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Search">
        <button onclick="searchVideos()">🔍</button>
    </div>

    <div class="profile">A</div>
</div>

<!-- Sidebar -->
<div class="sidebar">
    <ul>
        <li>🏠 Home</li>
        <li>🎬 Shorts</li>
        <li>📺 Subscriptions</li>
        <li>📚 Library</li>
        <li>🕒 History</li>
    </ul>
</div>

<!-- Main -->
<div class="main">
    <div class="video-grid" id="videoGrid">

        <div class="video-card">
            <div class="thumbnail">
                <img src="https://picsum.photos/400/250?1">
            </div>
            <div class="video-info">
                <div class="channel-icon">T</div>
                <div class="video-details">
                    <h4>Learn JavaScript in One Video</h4>
                    <p>Tech Channel</p>
                    <p>1.2M views • 2 days ago</p>
                </div>
            </div>
        </div>

        <div class="video-card">
            <div class="thumbnail">
                <img src="https://picsum.photos/400/250?2">
            </div>
            <div class="video-info">
                <div class="channel-icon">C</div>
                <div class="video-details">
                    <h4>Complete CSS Course</h4>
                    <p>Code Academy</p>
                    <p>850K views • 1 week ago</p>
                </div>
            </div>
        </div>

        <div class="video-card">
            <div class="thumbnail">
                <img src="https://picsum.photos/400/250?3">
            </div>
            <div class="video-info">
                <div class="channel-icon">W</div>
                <div class="video-details">
                    <h4>Web Development Roadmap</h4>
                    <p>Web Master</p>
                    <p>2.5M views • 3 weeks ago</p>
                </div>
            </div>
        </div>

        <div class="video-card">
            <div class="thumbnail">
                <img src="https://picsum.photos/400/250?4">
            </div>
            <div class="video-info">
                <div class="channel-icon">D</div>
                <div class="video-details">
                    <h4>React JS Crash Course</h4>
                    <p>Dev World</p>
                    <p>600K views • 5 days ago</p>
                </div>
            </div>
        </div>

        <div class="video-card">
            <div class="thumbnail">
                <img src="https://picsum.photos/400/250?5">
            </div>
            <div class="video-info">
                <div class="channel-icon">P</div>
                <div class="video-details">
                    <h4>Python for Beginners</h4>
                    <p>Programming Hub</p>
                    <p>3M views • 1 month ago</p>
                </div>
            </div>
        </div>

        <div class="video-card">
            <div class="thumbnail">
                <img src="https://picsum.photos/400/250?6">
            </div>
            <div class="video-info">
                <div class="channel-icon">G</div>
                <div class="video-details">
                    <h4>Gaming Highlights 2025</h4>
                    <p>Gaming Zone</p>
                    <p>900K views • 6 days ago</p>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
function searchVideos() {
    let input = document.getElementById("searchInput").value.toLowerCase();
    let videos = document.querySelectorAll(".video-card");

    videos.forEach(video => {
        let title = video.querySelector("h4").textContent.toLowerCase();

        if(title.includes(input)){
            video.style.display = "block";
        } else {
            video.style.display = "none";
        }
    });
}
</script>

</body>
</html>
